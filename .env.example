# ─── Auth0 ──────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-portal-client-id
AUTH0_CLIENT_SECRET=your-portal-client-secret
AUTH0_AUDIENCE=https://api.drift.ai
AUTH0_BASE_URL=http://localhost:3000
AUTH0_SECRET=generate-with-openssl-rand-hex-32

# Auth0 M2M (for agent provisioning via Management API)
AUTH0_M2M_CLIENT_ID=your-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret

# ─── App URLs ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
PORTAL_URL=http://localhost:3000

# ─── Internal communication ──────────────────────────
DRIFT_INTERNAL_API_KEY=drift_internal_dev_key_change_me
DRIFT_API_URL=http://localhost:4000

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://drift:drift@localhost:5432/drift_db

# ─── Security ────────────────────────────────────────
# Must be exactly 32 characters for HMAC-SHA256 key derivation
DRIFT_ENCRYPTION_KEY=change-me-32-chars-exactly-here!
DRIFT_WEBHOOK_SECRET=generate-webhook-secret-here

# ─── AI (Apex) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Demo APIs (sandboxes) ───────────────────────────
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ─── Other ───────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
PORT=4000
