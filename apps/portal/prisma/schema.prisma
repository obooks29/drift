// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant ────────────────────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  auth0OrgId String? @unique
  name      String
  plan      Plan     @default(FREE)
  apiKey    String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents      Agent[]
  ledgerEntries LedgerEntry[]

  @@map("tenants")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// ─── Agent ────────────────────────────────────────────────────────────────
model Agent {
  id            String      @id @default(cuid())
  agentId       String      @unique  // drift_agt_xxxxxxxxxxxx
  name          String
  description   String?
  status        AgentStatus @default(PENDING)
  scopes        String[]
  stepUpScopes  String[]
  delegatedBy   String      // email of authorizing human
  governedBy    String      @default("apex")
  auth0ClientId String?     // Auth0 M2M app client ID
  trustCert     String?     // Signed JWT
  metadata      Json?
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastActiveAt  DateTime?

  consentRecords ConsentRecord[]
  ledgerEntries  LedgerEntry[]

  @@index([tenantId, status])
  @@index([agentId])
  @@map("agents")
}

enum AgentStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

// ─── Consent Record (ConsentChain) ────────────────────────────────────────
model ConsentRecord {
  id             String            @id @default(cuid())
  agentId        String
  agent          Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scope          String
  action         String
  requestedAt    DateTime          @default(now())
  resolvedAt     DateTime?
  resolution     ConsentResolution?
  approvedBy     String?
  cibaRequestId  String?           @unique

  @@index([agentId])
  @@map("consent_records")
}

enum ConsentResolution {
  APPROVED
  REJECTED
  TIMEOUT
}

// ─── Ledger Entry (ActionLedger) ──────────────────────────────────────────
model LedgerEntry {
  id        String        @id @default(cuid())
  agentId   String
  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action    String
  scope     String
  resource  String?
  result    LedgerResult
  metadata  Json?
  ipAddress String?
  timestamp DateTime      @default(now())

  @@index([agentId, timestamp(sort: Desc)])
  @@index([tenantId, timestamp(sort: Desc)])
  @@map("ledger_entries")
}

enum LedgerResult {
  SUCCESS
  BLOCKED
  STEP_UP_REQUIRED
  TIMEOUT
}
